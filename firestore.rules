rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    function isValidCharacter(data) {
      return data.keys().hasAll(['id', 'serial', 'name', 'costume', 'props', 'isChecked'])
        && data.id is string && data.id.size() <= 128
        && data.serial is string && data.serial.size() <= 100
        && data.name is string && data.name.size() <= 200
        && data.costume is string && data.costume.size() <= 2000
        && data.props is string && data.props.size() <= 2000
        && data.isChecked is bool
        && (!data.keys().hasAny(['checkedCostumes']) || (data.checkedCostumes is list && data.checkedCostumes.size() <= 100))
        && (!data.keys().hasAny(['checkedProps']) || (data.checkedProps is list && data.checkedProps.size() <= 100));
    }

    match /characters/{characterId} {
      // Publicly accessible as per user explicit request for shared global checklist without sign-in
      allow read: if true;
      
      allow create: if isValidId(characterId)
        && isValidCharacter(incoming());

      allow update: if isValidId(characterId)
        && isValidCharacter(incoming())
        && incoming().id == existing().id
        && incoming().diff(existing()).affectedKeys().hasOnly(['serial', 'name', 'costume', 'props', 'isChecked', 'checkedCostumes', 'checkedProps']);
        
      allow delete: if isValidId(characterId);
    }
  }
}
